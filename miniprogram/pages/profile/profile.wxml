<!-- profile.wxml -->
<view class="container">
    <view class="card">
        <view class="card-title">编辑个人信息</view>
        <form bindsubmit="onSubmit">
            <!-- 头像上传区域 -->
            <view class="avatar-section">
                <view class="avatar-container" bindtap="chooseAvatar">
                    <image class="avatar" src="{{form.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
                    <view class="avatar-edit-icon">📷</view>
                </view>
                <text class="avatar-tip">点击更换头像</text>
            </view>
            <!-- 用户名输入 -->
            <view class="form-row">
                <view class="form-label">用户名</view>
                <input class="form-input" name="username" value="{{form.username}}" placeholder="请输入用户名" />
            </view>
            <view class="form-row">
                <view class="form-label">昵称</view>
                <input class="form-input" name="nickName" value="{{form.nickName}}" placeholder="请输入昵称" />
            </view>
            <button class="btn-primary" formType="submit">保存</button>
        </form>
    </view>
</view>