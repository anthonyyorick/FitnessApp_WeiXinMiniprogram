/* about/privacy-policy.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 标签页样式 */
.tab-header {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
  color: white;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 26rpx;
  font-weight: 600;
}

/* 内容区域样式 */
.content-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.content-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.content-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.content-date {
  font-size: 24rpx;
  color: #999;
}

.content-body {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.policy-section {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.policy-section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 15rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid #ff6b6b;
}

.section-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-line;
}

/* 联系方式样式 */
.contact-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.contact-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.contact-item:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.contact-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}

.contact-info {
  flex: 1;
}

.contact-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.contact-action {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: #ffeaea;
  border-radius: 6rpx;
}

/* 底部样式 */
.footer {
  text-align: center;
  padding: 40rpx 20rpx;
  color: #999;
}

.footer-text {
  font-size: 28rpx;
  margin-bottom: 15rpx;
  line-height: 1.6;
}

.footer-note {
  font-size: 24rpx;
  opacity: 0.8;
  line-height: 1.5;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .container {
    padding: 15rpx;
  }

  .content-section,
  .contact-section {
    padding: 20rpx;
  }

  .content-title {
    font-size: 32rpx;
  }

  .section-title {
    font-size: 28rpx;
  }

  .section-content {
    font-size: 24rpx;
  }
}
