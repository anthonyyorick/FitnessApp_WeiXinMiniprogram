/* course.wxss */
.search-bar {
  display: flex;
  align-items: center;
  /* margin-bottom: 20rpx; */
  background: #fff;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.09);
}
.search-input {
  flex: 1;
  border: none;
  font-size: 28rpx;
  padding: 16rpx 10rpx;
  background: transparent;
}
.search-btn {
  color: #4caf50;
  font-size: 28rpx;
  margin-left: 20rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.course-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.course-item:last-child {
  border-bottom: none;
}
.course-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}
.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.course-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}
.course-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}
.course-meta {
  display: flex;
  font-size: 24rpx;
  color: #999;
  gap: 20rpx;
}
