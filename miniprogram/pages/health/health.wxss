/* health.wxss */
.container {
  padding: 20rpx;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-primary {
  color: #4caf50;
  font-size: 28rpx;
}

.tab-bar {
  display: flex;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}
.tab-item.active {
  background: #4caf50;
  color: #fff;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.chart-container {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  min-height: 400rpx;
}

.chart-wrapper {
  width: 100%;
  height: 320rpx;
  position: relative;
}

.chart-canvas {
  width: 100% !important;
  height: 100% !important;
}

.chart-container ec-canvas {
  width: 100% !important;
  height: 320rpx !important;
}

.health-indicator {
  text-align: center;
  padding: 20rpx 0;
}
.health-indicator .value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4caf50;
  margin-bottom: 10rpx;
}
.health-indicator .label {
  font-size: 24rpx;
  color: #666;
}
.health-indicator .unit {
  font-size: 20rpx;
  color: #999;
}
.health-indicator .time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.record-item:last-child {
  border-bottom: none;
}
.record-value {
  font-size: 28rpx;
  color: #333;
}
.record-time {
  font-size: 22rpx;
  color: #999;
}

.text-center {
  text-align: center;
}

.text-secondary {
  color: #999;
  font-size: 28rpx;
}
