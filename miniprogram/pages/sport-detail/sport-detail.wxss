/* sport-detail.wxss */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}
.track-placeholder,
.pace-placeholder {
  height: 180rpx;
  background: #f5f5f5;
  color: #bbb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-radius: 8rpx;
}

/* 新增地图和运动控制样式 */
.realtime-info {
  display: flex;
  justify-content: space-between;
  margin: 16rpx 0 8rpx 0;
  padding: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}
.realtime-info text {
  text-align: center;
  flex: 1;
}
.btn-group {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 12rpx;
}
button[type="primary"] {
  background: linear-gradient(90deg, #36d1c4, #5b86e5);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}
button[type="warn"] {
  background: linear-gradient(90deg, #ff5858, #f09819);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}
