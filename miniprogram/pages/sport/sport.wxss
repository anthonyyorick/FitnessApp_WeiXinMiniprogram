/* sport.wxss */
.container{
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  /* box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08); */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.text-primary{
  font-size: 24rpx;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}
.tab-item.active {
  background: #4CAF50;
  color: #fff;
}
.grid-4 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 20rpx;
}
.health-indicator {
  text-align: center;
  padding: 20rpx 0;
}
.health-indicator .value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4caf50;
  margin-bottom: 10rpx;
}
.health-indicator .label {
  font-size: 22rpx;
  color: #666;
}
.health-indicator .unit {
  font-size: 18rpx;
  color: #999;
}
.sport-record {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.sport-record .header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.sport-record .type-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
}
.sport-record .type-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.sport-record .data {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.sport-record .data-item {
  text-align: center;
}
.sport-record .data-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4caf50;
}
.sport-record .data-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 5rpx;
}
.sport-record .time {
  font-size: 24rpx;
  color: #999;
  text-align: right;
}
.floating-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  background: #4caf50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
  z-index: 1000;
}
.floating-btn .icon {
  width: 60rpx;
  height: 60rpx;
  color: #fff;
  font-size: 60rpx;
  text-align: center;
  justify-content: center;
  align-items: center;
  line-height: 60rpx;
}
