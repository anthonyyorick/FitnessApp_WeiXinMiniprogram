<!-- index.wxml -->
<view class="container">
    <!-- 健康概览卡片 -->
    <view class="card healthCard">
        <view class="grid-3">
            <health-card title="平均心率" value="{{healthData.heartRate}}" unit="bpm" type="heartRate" bindtap="goToHealthDetail"></health-card>
            <health-card title="今日步数" value="{{healthData.steps}}" unit="步" type="steps" bindtap="goToHealthDetail"></health-card>
            <health-card title="睡眠质量" value="{{healthData.sleep}}" unit="{{healthData.sleepUnit}}" type="sleep" bindtap="goToHealthDetail"></health-card>
        </view>
    </view>
    <!-- 热门训练 -->
    <view class="card">
        <view class="flex-between">
            <view class="card-title">热门训练</view>
            <view class="text-primary" bindtap="goToCourseList">查看全部</view>
        </view>
        <view class="grid-2">
            <course-card wx:for="{{courses}}" wx:key="id" id="{{item.id}}" title="{{item.title}}" description="{{item.description}}" duration="{{item.duration}}" level="{{item.level}}" cover="{{item.cover}}" bindtap="goToCourseDetail"></course-card>
        </view>
        <!-- 训练列表 -->
        <view class="course-list">
            <view class="course-item" wx:for="{{courseList}}" wx:key="id" bindtap="goToCourseDetail" data-id="{{item.id}}">
                <image class="course-image" src="{{item.cover}}" mode="aspectFill"></image>
                <view class="course-info">
                    <view class="course-title">{{item.title}}</view>
                    <view class="course-desc">{{item.description}}</view>
                    <view class="course-meta">
                        <text class="course-duration">{{item.duration}}分钟</text>
                        <text class="course-level">{{item.level}}</text>
                    </view>
                </view>
            </view>
        </view>
    </view>
    <!-- 快捷功能 -->
    <view class="card quick-nav">
        <view class="card-title">快捷功能</view>
        <view class="grid-2">
            <view class="quick-action sport-action" bindtap="startSport">
                <view class="icon"><image src="https://pic1.zhimg.com/100/v2-3f815ae3da2b3b137e70e4df2a154e8e_r.jpg" mode=""/></view>
                <view class="text">开始运动</view>
            </view>
            <view class="quick-action health-action" bindtap="recordHealth">
                <view class="icon"><image src="https://pic1.zhimg.com/100/v2-0662d01210f628ca8f44d85afeef758a_r.jpg" mode=""/></view>
                <view class="text">记录指标</view>
            </view>
        </view>
    </view>
    <!-- 健康小贴士 -->
    <view class="card tips">
        <view class="card-title">健康小贴士</view>
        <view class="text-secondary">{{healthTip}}</view>
    </view>
</view>