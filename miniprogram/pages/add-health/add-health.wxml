<!-- add-health.wxml -->
<view class="container">
    <!-- 顶部导航 -->
    <view class="nav-bar">
        <view class="nav-left" bindtap="goBack">
            <text class="nav-icon">←</text>
        </view>
        <view class="nav-title">添加健康记录</view>
        <view class="nav-right"></view>
    </view>
    <view class="content">
        <!-- 健康指标类型选择 -->
        <view class="type-selector">
            <view class="type-title">选择健康指标</view>
            <view class="type-grid">
                <view class="type-item {{healthTypeIndex === 0 ? 'active' : ''}}" bindtap="selectHealthType" data-index="0">
                    <text class="type-icon">❤️</text>
                    <text class="type-name">心率</text>
                </view>
                <view class="type-item {{healthTypeIndex === 1 ? 'active' : ''}}" bindtap="selectHealthType" data-index="1">
                    <text class="type-icon">🩸</text>
                    <text class="type-name">血压</text>
                </view>
                <view class="type-item {{healthTypeIndex === 2 ? 'active' : ''}}" bindtap="selectHealthType" data-index="2">
                    <text class="type-icon">😴</text>
                    <text class="type-name">睡眠</text>
                </view>
                <view class="type-item {{healthTypeIndex === 3 ? 'active' : ''}}" bindtap="selectHealthType" data-index="3">
                    <text class="type-icon">⚖️</text>
                    <text class="type-name">体重</text>
                </view>
            </view>
        </view>
        <!-- 数据输入表单 -->
        <view class="form-card">
            <view class="form-title">{{healthTypes[healthTypeIndex]}}记录</view>
            <!-- 心率输入 -->
            <view class="form-section" wx:if="{{healthTypeIndex === 0}}">
                <view class="input-group">
                    <view class="input-label">心率值 (bpm)</view>
                    <input class="form-input" type="number" value="{{form.heartRate}}" placeholder="请输入心率，如：75" data-field="heartRate" bindinput="onInput" />
                    <view class="input-tip">正常范围：40-200 bpm</view>
                </view>
            </view>
            <!-- 血压输入 -->
            <view class="form-section" wx:if="{{healthTypeIndex === 1}}">
                <view class="input-group">
                    <view class="input-label">收缩压/舒张压 (mmHg)</view>
                    <input class="form-input" type="text" value="{{form.bloodPressure}}" placeholder="如：120/80" data-field="bloodPressure" bindinput="onInput" />
                    <view class="input-tip">格式：收缩压/舒张压，如：120/80</view>
                </view>
            </view>
            <!-- 睡眠输入 -->
            <view class="form-section" wx:if="{{healthTypeIndex === 2}}">
                <view class="input-group">
                    <view class="input-label">睡眠时长 (小时)</view>
                    <input class="form-input" type="digit" value="{{form.sleep}}" placeholder="请输入睡眠时长，如：7.5" data-field="sleep" bindinput="onInput" />
                    <view class="input-tip">建议：7-9小时</view>
                </view>
            </view>
            <!-- 体重输入 -->
            <view class="form-section" wx:if="{{healthTypeIndex === 3}}">
                <view class="input-group">
                    <view class="input-label">体重 (kg)</view>
                    <input class="form-input" type="digit" value="{{form.weight}}" placeholder="请输入体重，如：65.5" data-field="weight" bindinput="onInput" />
                    <view class="input-tip">正常范围：20-300 kg</view>
                </view>
            </view>
            <!-- 记录时间 -->
            <view class="form-section">
                <view class="input-group">
                    <view class="input-label">记录时间</view>
                    <picker mode="date" value="{{recordDate}}" bindchange="onDateChange">
                        <view class="picker-value">{{recordDate || '选择日期'}}</view>
                    </picker>
                    <picker mode="time" value="{{recordTime}}" bindchange="onTimeChange">
                        <view class="picker-value">{{recordTime || '选择时间'}}</view>
                    </picker>
                </view>
            </view>
            <!-- 备注 -->
            <view class="form-section">
                <view class="input-group">
                    <view class="input-label">备注 (可选)</view>
                    <textarea class="form-textarea" value="{{form.notes}}" placeholder="添加备注信息..." data-field="notes" bindinput="onInput" />
                </view>
            </view>
        </view>
        <!-- 快捷输入 -->
        <!-- <view class="quick-input" wx:if="{{healthTypeIndex === 0}}">
            <view class="quick-title">快捷输入</view>
            <view class="quick-buttons">
                <button class="quick-btn" bindtap="quickInput" data-value="60">60</button>
                <button class="quick-btn" bindtap="quickInput" data-value="70">70</button>
                <button class="quick-btn" bindtap="quickInput" data-value="80">80</button>
                <button class="quick-btn" bindtap="quickInput" data-value="90">90</button>
                <button class="quick-btn" bindtap="quickInput" data-value="100">100</button>
            </view>
        </view> -->
        <!-- 操作按钮 -->
        <view class="action-buttons">
            <button class="btn-secondary" bindtap="resetForm">重置</button>
            <button class="btn-primary" bindtap="submitForm" loading="{{submitting}}">
                {{submitting ? '保存中...' : '保存记录'}}
            </button>
        </view>
    </view>
</view>