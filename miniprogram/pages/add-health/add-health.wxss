/* add-health.wxss */
.container {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.nav-left {
  width: 60rpx;
}

.nav-icon {
  font-size: 36rpx;
  color: #333;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.nav-right {
  width: 60rpx;
}

.content {
  padding: 20rpx;
}

/* 类型选择器 */
.type-selector {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.type-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  background: #fafafa;
  transition: all 0.3s;
}

.type-item.active {
  border-color: #4caf50;
  background: #e8f5e8;
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.type-name {
  font-size: 24rpx;
  color: #333;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.form-section {
  margin-bottom: 30rpx;
}

.input-group {
  display: flex;
  flex-direction: column;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  margin-bottom: 8rpx;
}

.form-textarea {
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.input-tip {
  font-size: 24rpx;
  color: #999;
}

/* 时间选择器 */
.picker-value {
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  color: #333;
  margin-bottom: 10rpx;
}

/* 快捷输入 */
.quick-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.quick-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.quick-buttons {
  display: flex;
  gap: 15rpx;
  flex-wrap: wrap;
}

.quick-btn {
  background: #f0f0f0;
  border: none;
  border-radius: 8rpx;
  padding: 15rpx 25rpx;
  font-size: 28rpx;
  color: #333;
  min-width: 80rpx;
  text-align: center;
}

.quick-btn:active {
  background: #e0e0e0;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-primary {
  flex: 2;
  background: #4caf50;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 25rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-secondary {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 25rpx;
  font-size: 30rpx;
}

.btn-primary:active {
  background: #45a049;
}

.btn-secondary:active {
  background: #e8e8e8;
}
