/* add-sport.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #4caf50;
  padding-left: 20rpx;
}

/* 运动类型选择 */
.sport-types {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.sport-type-item {
  flex: 1;
  min-width: 120rpx;
  text-align: center;
  padding: 30rpx 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
  transition: all 0.3s ease;
}

.sport-type-item.active {
  border-color: #4caf50;
  background: #e8f5e8;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
}

.sport-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.sport-name {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.sport-type-item.active .sport-name {
  color: #4caf50;
  font-weight: 600;
}

/* 表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
}

.form-input:focus {
  border-color: #4caf50;
  outline: none;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
  resize: none;
  transition: border-color 0.3s ease;
}

.form-textarea:focus {
  border-color: #4caf50;
  outline: none;
}

/* 时长输入组 */
.duration-input-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 100%;
  margin-bottom: 15rpx;
}

.duration-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  text-align: center;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
}

.duration-input:focus {
  border-color: #4caf50;
  outline: none;
}

.duration-separator {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
  padding: 0 10rpx;
}

/* 时长显示 */
.duration-display {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #4caf50;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #4caf50;
  background: #e8f5e8;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.duration-label {
  color: #666;
  margin-right: 10rpx;
}

.duration-value {
  color: #4caf50;
  font-weight: 700;
  font-size: 32rpx;
}

/* 时间选择器 */
.picker-value {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-value:empty::before {
  content: attr(placeholder);
  color: #999;
}

/* 输入提示 */
.input-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.4;
}

/* 位置信息 */
.location-info {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e9ecef;
}

.location-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.location-coords {
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.btn-primary[disabled] {
  background: #ccc;
  box-shadow: none;
  transform: none;
}

.btn-secondary {
  background: #fff;
  color: #666;
  border: 2rpx solid #e0e0e0;
}

.btn-secondary:active {
  background: #f5f5f5;
  transform: translateY(2rpx);
}

.btn-secondary[disabled] {
  background: #f5f5f5;
  color: #ccc;
  border-color: #e0e0e0;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .sport-types {
    gap: 15rpx;
  }

  .sport-type-item {
    min-width: 100rpx;
    padding: 20rpx 15rpx;
  }

  .sport-icon {
    font-size: 40rpx;
  }

  .sport-name {
    font-size: 24rpx;
  }
}

/* 加载状态 */
.loading {
  opacity: 0.6;
  pointer-events: none;
}

/* 错误状态 */
.form-input.error {
  border-color: #f44336;
}

.error-message {
  font-size: 24rpx;
  color: #f44336;
  margin-top: 8rpx;
}

/* 成功状态 */
.form-input.success {
  border-color: #4caf50;
}

/* 提示信息 */
.hint-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.4;
}

/* 必填字段标识 */
.required::after {
  content: "*";
  color: #f44336;
  margin-left: 4rpx;
}
