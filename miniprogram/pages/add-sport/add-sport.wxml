        <!-- 位置信息 -->
        <view class="section" wx:if="{{location}}">
            <view class="section-title">位置信息</view>
            <view class="location-info">
                <view class="location-text">{{location.address || '当前位置'}}</view>
                <view class="location-coords">
                    纬度: {{location.latitude}}, 经度: {{location.longitude}}
                </view>
            </view>
        </view>
        <!-- 操作按钮 -->
        <view class="action-buttons">
            <button class="btn btn-secondary" bindtap="resetForm" disabled="{{submitting}}">
                重置
            </button>
            <button class="btn btn-primary" form-type="submit" loading="{{submitting}}" disabled="{{submitting}}">
                {{submitting ? '提交中...' : '保存记录'}}
            </button>
        </view>
    </form>
</view>