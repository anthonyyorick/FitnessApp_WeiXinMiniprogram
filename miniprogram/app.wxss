app.wxss
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", "Oxygen",
    "Ubuntu", "Cantarell", "Fira Sans", "Droid Sans", "Helvetica Neue",
    sans-serif;
}

.container {
  padding: 10rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  /* box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1); */
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: #4caf50;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.text-primary {
  color: #4caf50;
  font-size: 26rpx;
}

.text-secondary {
  color: #666;
}

.text-center {
  text-align: center;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.grid-4 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 20rpx;
}

.mt-10 {
  margin-top: 10rpx;
}
.mt-20 {
  margin-top: 20rpx;
}
.mt-30 {
  margin-top: 30rpx;
}
.mb-10 {
  margin-bottom: 10rpx;
}
.mb-20 {
  margin-bottom: 20rpx;
}
.mb-30 {
  margin-bottom: 30rpx;
}

.health-indicator {
  text-align: center;
  padding: 20rpx;
}

.health-indicator .value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4caf50;
  margin-bottom: 10rpx;
}

.health-indicator .label {
  font-size: 24rpx;
  color: #666;
}

.health-indicator .unit {
  font-size: 20rpx;
  color: #999;
}

.quick-action {
  text-align: center;
  padding: 30rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.quick-action .icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 15rpx;
}

.quick-action .text {
  font-size: 24rpx;
  color: #333;
}

.course-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.course-card .cover {
  width: 100%;
  height: 200rpx;
  background: #f0f0f0;
}

.course-card .info {
  padding: 20rpx;
}

.course-card .title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.course-card .duration {
  font-size: 24rpx;
  color: #666;
}

.sport-record {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.sport-record .header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.sport-record .type-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.sport-record .type-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.sport-record .data {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.sport-record .data-item {
  text-align: center;
}

.sport-record .data-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4caf50;
}

.sport-record .data-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 5rpx;
}

.sport-record .time {
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.floating-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  background: #4caf50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
  z-index: 1000;
}

.floating-btn .icon {
  width: 60rpx;
  height: 60rpx;
  color: #fff;
}

.tab-bar {
  display: flex;
  background: #F9FFF9;
  border-radius: 12rpx;
  padding: 10rpx;
  /* margin-bottom: 20rpx; */
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  background: #4caf50;
  color: #fff;
}

.chart-container {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-info .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.user-info .info {
  flex: 1;
}

.user-info .nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.user-info .signature {
  font-size: 28rpx;
  color: #666;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item .icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-item .text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-item .arrow {
  width: 20rpx;
  height: 20rpx;
  color: #999;
}
