/* course-card.wxss */
.course-card {
  /* background: linear-gradient(135deg, #b2ebf2 0%, #81d4fa 100%); */
  margin-top: 10rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.09);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
}

.course-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(129, 212, 250, 0.7);
}

.course-cover {
  width: 100%;
  height: 200rpx;
  background: #f0f0f0;
  background-size: cover;
  background-position: center;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.course-icon {
  width: 56rpx;
  height: 56rpx;
  position: absolute;
  left: 24rpx;
  bottom: 24rpx;
  opacity: 0.85;
}

.course-level {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(90deg, #4fc3f7, #29b6f6);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(41, 182, 246, 0.4);
}

.course-info {
  padding: 24rpx;
  border-radius: 0 0 16rpx 16rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(8rpx);
  box-shadow: 0 2rpx 8rpx rgba(91, 134, 229, 0.06);
}

.course-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #263238;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-desc {
  font-size: 24rpx;
  color: #0288d1;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #455a64;
}

.course-duration {
  color: #212121;
}

.glass-effect {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(8rpx);
}
