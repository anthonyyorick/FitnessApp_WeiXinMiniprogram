/* health-card.wxss */
.health-card {
  /* 背景色现在通过动态样式设置 */
  border-radius: 20rpx;
  padding: 36rpx 30rpx 30rpx 30rpx;
  /* margin-bottom: 24rpx; */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.09);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
}

.health-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.health-icon {
  width: 50rpx;
  height: 50rpx;
  position: absolute;
  left: 20rpx;
  top: 32rpx;
  opacity: 0.85;
}

.card-header {
  margin-bottom: 20rpx;
  padding-left: 50rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #212121;
  /* margin-bottom: 20rpx; */
  line-height: 45rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #43a047;
}

.card-content {
  text-align: center;
  margin-bottom: 5rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.main-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #7E57C2;
  margin-bottom: 8rpx;
}

.unit {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: 	#616161;
}

.card-footer {
  text-align: center;
}

.footer-text {
  font-size: 22rpx;
  color: #66bb6a;
}

.glass-effect {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}
